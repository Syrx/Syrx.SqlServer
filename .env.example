# ============================================================
# Syrx.SqlServer — Environment Variable Template
# ============================================================
# Copy this file to .env and fill in your values.
# The .env file is git-ignored and must NEVER be committed.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your real values
#   # Integration tests and docker-compose will pick up values automatically
# ============================================================

# SQL Server SA password used by the test Docker container.
# Must satisfy SQL Server complexity requirements:
#   - At least 8 characters
#   - Uppercase, lowercase, number, and symbol
MSSQL_SA_PASSWORD=YourStrong!Passw0rd
